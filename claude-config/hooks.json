{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "command": ".claude/hooks/post-edit-review.sh"
      },
      {
        "matcher": "Write",
        "command": ".claude/hooks/post-edit-review.sh"
      },
      {
        "matcher": "Bash",
        "command": ".claude/hooks/post-build-verify.sh"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": ".claude/hooks/pre-commit-check.sh",
        "pattern": "git commit"
      }
    ]
  }
}
